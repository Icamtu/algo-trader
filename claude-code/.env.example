# =============================================================================
# Claude Code LLM Routing Configuration
# =============================================================================
LLM_PROVIDER=auto                      # options: auto, ollama, openrouter
PREFER_LOCAL=true                      # set to true for Ollama priority

# Ollama (Local)
OLLAMA_BASE_URL=http://local_ollama:11434  # URL of the Ollama service
OLLAMA_MODEL=llama3.2                  # default local model
OLLAMA_API_KEY=                        # optional, if your Ollama requires it

# OpenRouter (Cloud Fallback)
OPENROUTER_API_KEY=your_openrouter_key  # required for cloud fallback/direct use
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# Claude Code CLI (Native)
ANTHROPIC_API_KEY=your_anthropic_key    # required if using Anthropic directly

# =============================================================================
# Project Infrastructure & Secrets
# =============================================================================
# These match the variables used in the root docker-compose.yml

# Security Keys
APP_KEY=                                # generated via: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_PEPPER=                         # another random hex string for hashing

# Database & Auth (Supabase Stack)
POSTGRES_PASSWORD=                      # postgres superuser password
SUPABASE_AUTH_ADMIN_PASSWORD=           # auth admin user password
JWT_SECRET=                             # jwt signing secret
ANON_KEY=                               # supabase anonymous key
SERVICE_ROLE_KEY=                       # supabase service role key (bypass RLS)

# Redis
REDIS_PASSWORD=                         # redis access password

# Telegram Bot
TELEGRAM_BOT_TOKEN=                     # for notifications/alerts

# Broker Configuration (OpenAlgo)
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_API_KEY_MARKET=
BROKER_API_SECRET_MARKET=

# =============================================================================
# Container Configuration
# =============================================================================
PORT=8080                              # container internal port
WORKSPACE_DIR=./workspace              # local path for persistence
TZ=Asia/Kolkata                        # container timezone
