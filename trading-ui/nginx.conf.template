map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name localhost;

    server_tokens off;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    # Fix: added style-src-elem cdn.jsdelivr.net (Monaco CSS), worker-src blob: (Monaco workers),
    # blob: to script-src, and cdn.jsdelivr.net to connect-src (source maps)
    # TradingView: s3.tradingview.com for scripts, frame-src for widget iframe, connect-src for data
    add_header Content-Security-Policy "default-src 'self'; frame-src 'self' https://*.tradingview.com https://*.tradingview-widget.com https://s3.tradingview.com https://s.tradingview.com; child-src 'self' https://*.tradingview.com https://*.tradingview-widget.com https://s3.tradingview.com https://s.tradingview.com blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://s3.tradingview.com https://s.tradingview.com https://*.tradingview.com blob:; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://*.tradingview.com; style-src-elem 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://*.tradingview.com; font-src 'self' data: https://fonts.gstatic.com https://*.tradingview.com; img-src 'self' data: https://*; connect-src 'self' *; worker-src blob: 'self';" always;

    # Resolver for Docker DNS
    resolver 127.0.0.11 valid=30s;

    location / {
        root /usr/share/nginx/html;
        index index.html index.htm;
        try_files $uri $uri/ /index.html;

        # IMPORTANT: nginx drops all parent add_header directives when any add_header
        # appears in this block. All security headers must be repeated here.
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-XSS-Protection "1; mode=block" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Content-Security-Policy "default-src 'self'; frame-src 'self' https://*.tradingview.com https://*.tradingview-widget.com https://s3.tradingview.com https://s.tradingview.com; child-src 'self' https://*.tradingview.com https://*.tradingview-widget.com https://s3.tradingview.com https://s.tradingview.com blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://s3.tradingview.com https://s.tradingview.com https://*.tradingview.com blob:; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://*.tradingview.com; style-src-elem 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://*.tradingview.com; font-src 'self' data: https://fonts.gstatic.com https://*.tradingview.com; img-src 'self' data: https://*; connect-src 'self' http://${TAILSCALE_IP}:* http://localhost:* ws://${TAILSCALE_IP}:* ws://localhost:* wss://*.tradingview.com https://cdn.jsdelivr.net https://*.tradingview.com; worker-src blob: 'self';" always;
        expires off;
    }

    # Supabase Proxy
    location /supabase/ {
        set $supabase_upstream supabase-kong:8000;
        rewrite ^/supabase/(.*)$ /$1 break;
        proxy_pass http://$supabase_upstream;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Ensure apikey and Authorization headers are passed through
        proxy_pass_header apikey;
        proxy_pass_header Authorization;

        proxy_cache_bypass $http_upgrade;
    }


    # Algo-Engine API Proxy (Normalized)
    location /algo-api/ {
        set $engine_upstream algo_engine:18788;
        rewrite ^/algo-api/(.*)$ /$1 break;
        proxy_pass http://$engine_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 900;
        proxy_connect_timeout 900;
        proxy_send_timeout 900;
        proxy_pass_header apikey;
        proxy_pass_header Authorization;
    }

    # Institutional API v1 Proxy
    location /api/v1/ {
        set $engine_upstream algo_engine:18788;
        proxy_pass http://$engine_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass_header apikey;
        proxy_pass_header Authorization;
    }

    # System Metrics & Health Proxy (Institutional Mapping)
    location /api/system/ {
        set $engine_upstream algo_engine:18788;

        # Explicit mapping for known institutional paths
        rewrite ^/api/system/metrics/?(.*)$ /metrics$1 break;
        rewrite ^/api/system/health/?(.*)$ /api/v1/system/health$1 break;

        proxy_pass http://$engine_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass_header apikey;
        proxy_pass_header Authorization;
    }

    # WebSocket Logic Proxy (Config/Auth)
    location /api/websocket/ {
        set $engine_upstream algo_engine:18788;
        proxy_pass http://$engine_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass_header apikey;
        proxy_pass_header Authorization;
    }

    # WebSocket Proxy (Engine Relay - Unified FastAPI)
    location /algo-ws {
        set $engine_upstream algo_engine:18788;
        proxy_pass http://$engine_upstream/ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
        proxy_buffering off;
        proxy_cache off;
    }

    # Direct OpenAlgo Web (Fallback/Original)
    location /ws {
        set $openalgo_upstream openalgo-web:8765;
        proxy_pass http://$openalgo_upstream;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_read_timeout 86400;
    }


    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
    }
}
