# =============================================================================
# AetherDesk Prime — Environment Configuration Sample
# =============================================================================
# Copy this file to .env and fill in your credentials.
# DO NOT COMMIT THE ACTUAL .ENV FILE TO VERSION CONTROL.

# 1. CORE SYSTEM
ENV_CONFIG_VERSION=1.0.6
TAILSCALE_IP=100.x.x.x
VITE_API_HOST=${TAILSCALE_IP}
HOST_SERVER=http://${TAILSCALE_IP}
FLASK_HOST_IP=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=FALSE
FLASK_ENV=production
TZ=Asia/Kolkata

# 2. DATABASE CONFIGURATION
# Use sqlite:///db/yourdb.db for local storage
DATABASE_URL=sqlite:///db/openalgo.db
LATENCY_DATABASE_URL=sqlite:///db/latency.db
LOGS_DATABASE_URL=sqlite:///db/logs.db
SANDBOX_DATABASE_URL=sqlite:///db/sandbox.db
HISTORIFY_DATABASE_URL=db/historify.duckdb
SQLITE_MMAP_SIZE=268435456

# 3. CACHE & NETWORKING
REDIS_PASSWORD=your_redis_password_here
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8765
WEBSOCKET_URL=ws://${TAILSCALE_IP}:8765
ZMQ_HOST=0.0.0.0
ZMQ_PORT=5555

# 4. SECURITY (Required for Engine Start)
APP_KEY=generate_a_64_char_hex_key_here
API_KEY_PEPPER=generate_another_64_char_hex_key_here

# CORS Configuration
CORS_ENABLED=TRUE
CORS_ALLOWED_ORIGINS=http://${TAILSCALE_IP},http://${TAILSCALE_IP}:3000,http://${TAILSCALE_IP}:3001
CORS_ALLOW_CREDENTIALS=TRUE

# 5. BROKER CONFIGURATION (Shoonya Example)
VALID_BROKERS=shoonya
BROKER_API_KEY=your_broker_api_key
BROKER_API_SECRET=your_broker_api_secret
BROKER_IMEI=your_imei
VENDOR_CODE=your_vendor_code
REDIRECT_URL=https://your-domain/shoonya/callback
SHOONYA_USER_ID=your_user_id
SHOONYA_PASSWORD=your_password
SHOONYA_TOTP_SECRET=your_totp_secret

# Internal Connectivity
OPENALGO_API_KEY=your_internal_api_key
OPENALGO_BASE_URL=http://openalgo-web:5000
OPENALGO_DB_PATH=/app/db/openalgo.db

# 6. EXTERNAL SERVICES
OPENROUTER_API_KEY=your_openrouter_key_here
OLLAMA_API_KEY=your_ollama_key_here
OLLAMA_BASE_URL=http://ollama_engine:11434
LOCAL_LLM_MODEL=qwen3.5-claude:latest

# 7. TELEGRAM ALERTS
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 8. SUPABASE CONFIGURATION (Local Stack)
POSTGRES_PASSWORD=your_postgres_password_here
JWT_SECRET=your_jwt_secret_min_32_chars
ANON_KEY=your_supabase_anon_key
SERVICE_ROLE_KEY=your_supabase_service_role_key
SITE_URL=http://${TAILSCALE_IP}
GOTRUE_EXTERNAL_URL=http://${TAILSCALE_IP}/supabase/auth
API_EXTERNAL_URL=http://${TAILSCALE_IP}/supabase

# 9. TAILSCALE AUTOMATION
TAILSCALE_AUTH_KEY=tskey-auth-your-key-here
TAILSCALE_HOSTNAME=algo-engine
