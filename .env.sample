# =============================================================================
# AetherDesk Prime - Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CORE SYSTEM & NETWORKING
# -----------------------------------------------------------------------------
ENV_CONFIG_VERSION='1.0.6'
HOST_SERVER='http://127.0.0.1:5000' # The public or local IP where OpenAlgo is hosted
FLASK_HOST_IP='0.0.0.0'
FLASK_PORT=5000
FLASK_DEBUG=FALSE
TZ=Asia/Kolkata

# -----------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
DATABASE_URL='sqlite:///db/openalgo.db'
LATENCY_DATABASE_URL='sqlite:///db/latency.db'
LOGS_DATABASE_URL='sqlite:///db/logs.db'

# -----------------------------------------------------------------------------
# 3. CACHE & REDIS
# -----------------------------------------------------------------------------
# Get this from your Redis configuration or Docker Compose
REDIS_PASSWORD='your_redis_password_here'

# -----------------------------------------------------------------------------
# 4. SECURITY & OPENALGO KEYS
# -----------------------------------------------------------------------------
# APP_KEY: Generate a long random hex string (64 chars)
APP_KEY='generate_a_random_sha256_hash_here'
# API_KEY_PEPPER: Another long random hex string for hashing API keys
API_KEY_PEPPER='generate_another_random_sha256_hash_here'

# -----------------------------------------------------------------------------
# 5. BROKER CONFIGURATION (Shoonya / Finvasia)
# -----------------------------------------------------------------------------
VALID_BROKERS=shoonya

# BROKER_API_KEY: Your Shoonya Client ID + _U (e.g., FA12345_U)
# Get this from: https://trade.shoonya.com/ -> Profile -> API Key
BROKER_API_KEY='YOUR_ID_U'

# BROKER_API_SECRET: The "Secret Code" generated in the Shoonya portal.
# Get this from: https://trade.shoonya.com/ -> Profile -> API Key -> Secret Code
BROKER_API_SECRET='your_shoonya_secret_code_here'

# REDIRECT_URL: Must match the "URL" field in the Shoonya portal.
# Default for this project: https://trade.shoonya.com/OAuthlogin
REDIRECT_URL='https://trade.shoonya.com/OAuthlogin'

# SHOONYA_USER_ID: Your main Shoonya Login ID (e.g., FA12345)
SHOONYA_USER_ID='YOUR_ID'

# SHOONYA_PASSWORD: Your Shoonya Login Password
SHOONYA_PASSWORD='your_login_password'

# SHOONYA_TOTP_SECRET: The 32-character secret key used for 2FA.
# Get this from: https://prism.shoonya.com/ (Reset 2FA to see the secret code)
SHOONYA_TOTP_SECRET='your_32_char_totp_secret'

# -----------------------------------------------------------------------------
# 6. AI & LLM CONFIGURATION
# -----------------------------------------------------------------------------
# ANTHROPIC: Get from https://console.anthropic.com/
ANTHROPIC_API_KEY='sk-ant-...'

# OPENROUTER: Get from https://openrouter.ai/keys
OPENROUTER_API_KEY='sk-or-v1-...'

# OLLAMA: Base URL for local AI instance (usually http://local_ollama:11434 in Docker)
OLLAMA_BASE_URL='http://ollama_engine:11434'

# -----------------------------------------------------------------------------
# 7. SUPABASE (AUTH & DATABASE)
# -----------------------------------------------------------------------------
# Get these from your Supabase Project Settings -> API
POSTGRES_PASSWORD='your_postgres_password'
JWT_SECRET='your_long_jwt_secret_here'
ANON_KEY='your_supabase_anon_key'
SERVICE_ROLE_KEY='your_supabase_service_role_key'
SITE_URL='http://localhost:3001' # Your Frontend URL

# -----------------------------------------------------------------------------
# 8. TELEGRAM NOTIFICATIONS
# -----------------------------------------------------------------------------
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN='123456:ABC-DEF...'
# Get your Chat ID via @userinfobot or similar
TELEGRAM_CHAT_ID='your_telegram_chat_id'
