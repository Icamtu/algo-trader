{
  "project_name": "AetherDesk Prime",
  "version": "1.1.3",
  "services": {
    "algo_engine": {
      "name": "algo-trader",
      "port": 18788,
      "ws_port": 5002,
      "tech_stack": ["Python 3.12", "Flask", "DuckDB", "Redis"],
      "dependencies": ["redis", "openalgo-web"]
    },
    "trading_ui": {
      "name": "trading-ui",
      "port": 3001,
      "tech_stack": ["React 19", "Vite", "TypeScript", "Tailwind CSS"],
      "dependencies": ["supabase-kong", "algo_engine"]
    },
    "supbase_stack": {
      "name": "supabase",
      "port": 8000,
      "tech_stack": ["Postgres", "GoTrue", "Kong", "PostgREST"]
    },
    "ai_engine": {
      "name": "ollama",
      "port": 11434,
      "tech_stack": ["Ollama"]
    }
  },
  "file_structure": {
    "core_engine": "algo-trader/",
    "frontend": "trading-ui/",
    "auth_infra": "supabase/",
    "base_platform": "openalgo/",
    "database": "algo-trader/database/",
    "strategies": "algo-trader/strategies/"
  },
  "api_endpoints": [
    "/api/v1/health",
    "/api/v1/telemetry",
    "/api/v1/strategies",
    "/api/v1/strategies/<id>/start",
    "/api/v1/strategies/<id>/stop",
    "/api/v1/strategies/<id>/liquidate",
    "/api/v1/mode",
    "/api/v1/placeorder",
    "/api/v1/placesmartorder",
    "/api/v1/positionbook",
    "/api/v1/tradebook",
    "/api/v1/risk-metrics",
    "/api/v1/backtest/run",
    "/api/v1/actioncenter",
    "/api/v1/actioncenter/approve",
    "/historify/api/run-historify"
  ],
  "dependencies": {
    "python": [
      "pandas",
      "flask",
      "duckdb",
      "redis",
      "openalgo",
      "norenrestapioauth"
    ],
    "npm": [
      "react",
      "vite",
      "supabase-js",
      "tanstack/react-query",
      "zustand",
      "lucide-react",
      "shadcn/ui"
    ]
  }
}
